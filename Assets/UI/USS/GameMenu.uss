:root {
    width: 100%;
    height: 100%;
    -unity-background-scale-mode: scale-to-fit;
    background-size: 100% 100%;
    align-self: center;
    align-content: center;
    align-items: center;
    justify-content: center;
}

.unity-button {
    min-width: 0%;
    max-width: 50%;
    max-height: 50%;
    align-items: center;
    justify-content: center;
    align-self: center;
    align-content: center;
}
